{
  "permissions": {
    "deny": [
      "Bash(chmod -R 777 *)",
      "Bash(chmod 777 *)",
      "Bash(gh repo archive *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo edit *)",
      "Bash(git push * --force)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push origin --force *)",
      "Bash(git reset --hard *)",
      "Bash(rm -r -f *)",
      "Bash(rm -rf .)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)"
    ],
    "allow": [
      "Bash(gh repo create *)",
      "Bash(gh repo view *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git push origin *)",
      "Bash(git remote add *)",
      "Bash(git status *)",
      "Bash(git tag *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/drew/hackathons/privacy-track-colosseum-2026/.claude/hooks/pretooluse-safeguard.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
